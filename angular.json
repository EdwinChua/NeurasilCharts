{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "neurasil-charts": {
      "projectType": "library",
      "root": "projects/neurasil-charts",
      "sourceRoot": "projects/neurasil-charts/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "tsConfig": "projects/neurasil-charts/tsconfig.lib.json",
            "project": "projects/neurasil-charts/ng-package.json"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/neurasil-charts/tsconfig.spec.json",
            "buildTarget": "neurasil-charts:build",
            "runner": "vitest",
            "runnerConfig": "projects/neurasil-charts/vitest.config.ts"
          }
        },
      }
    },
    "neurasil-library-tester": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "sass"
        }
      },
      "root": "projects/neurasil-library-tester",
      "sourceRoot": "projects/neurasil-library-tester/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/neurasil-library-tester",
            "index": "projects/neurasil-library-tester/src/index.html",
            "browser": "projects/neurasil-library-tester/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/neurasil-library-tester/tsconfig.app.json",
            "assets": [
              "projects/neurasil-library-tester/src/favicon.ico",
              "projects/neurasil-library-tester/src/assets"
            ],
            "styles": [
              "projects/neurasil-library-tester/src/styles.sass"
            ],
            "scripts": []
          },
          "configurations": {
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/neurasil-library-tester/src/environments/environment.ts",
                  "with": "projects/neurasil-library-tester/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            },
            "defaultConfiguration": "development"
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "neurasil-library-tester:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "neurasil-library-tester:build:production"
            },
            "development": {
              "buildTarget": "neurasil-library-tester:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "neurasil-library-tester:build"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/neurasil-library-tester/tsconfig.spec.json",
            "runner": "vitest"
          }
        },
      }
    }},
  "defaultProject": "neurasil-charts",
  "cli": {
    "analytics": "eedaa5cb-233c-4f1e-83fb-31d8c0055c79"
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}